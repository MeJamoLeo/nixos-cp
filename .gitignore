# Whitelist approach: ignore everything, then allow specific files
*

# Nix
!flake.nix
!flake.lock

# NixOS config
!hosts/
!hosts/**/*.nix
!modules/
!modules/**/*.nix
!home/
!home/**/*.nix

# Dashboard
!dashboard/
!dashboard/dashboard.html
!dashboard/dashboard.py
!dashboard/fetch_stats.py
!dashboard/shell.nix
!dashboard/switch_user.sh
!dashboard/watchlist.json
!dashboard/js/
!dashboard/js/*.js

# Tools
!tools/
!tools/cp-*
!tools/README.md

# Dotfiles
!dotfiles/
!dotfiles/**/*

# Docs
!docs/
!docs/*.md

# Git
!.gitignore
