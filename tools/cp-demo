#!/usr/bin/env bash
# cp-demo — full workflow demo with a fixed easy problem
# Flow: setup → Firefox → nvim (solve + test with Space+cr) → tag → insight
set -euo pipefail

CP_DIR="$HOME/cp"
INSIGHTS_DIR="$CP_DIR/insights"
mkdir -p "$INSIGHTS_DIR"

# Fixed easy problem for demo
CONTEST="abc086"
PROBLEM="a"
PID="abc086_a"
URL="https://atcoder.jp/contests/abc086/tasks/abc086_a"

PROB_DIR="$CP_DIR/contests/$CONTEST/$PROBLEM"

echo "=== cp-demo ==="
echo ""
echo "Problem: $PID (Product)"
echo "  2つの正整数a,bが与えられる"
echo "  a*bが偶数なら\"Even\"、奇数なら\"Odd\"を出力"
echo ""

# --- Step 1: Setup ---
echo "[1/4] Setting up..."
mkdir -p "$PROB_DIR"
echo "$URL" > "$PROB_DIR/.problem_url"

# Download real test cases (no login needed)
if [[ ! -d "$PROB_DIR/test" ]]; then
    (cd "$PROB_DIR" && oj download "$URL" 2>/dev/null) || echo "(download skipped)"
fi

# Create starter file (with problem description, no solution)
cat > "$PROB_DIR/main.py" << 'PYEOF'
# ABC086 A - Product
# 2つの正整数a,bが与えられる。a*bが偶数なら"Even"、奇数なら"Odd"を出力
# https://atcoder.jp/contests/abc086/tasks/abc086_a
#
# テスト: Space+cr (competitest)
# 終わったら :wq で閉じる

PYEOF

echo "Done: $PROB_DIR"
echo ""

# --- Step 2: Open problem in browser ---
echo "[2/4] Opening problem page..."
if command -v firefox &>/dev/null; then
    firefox --new-tab "$URL" &>/dev/null &
    disown
fi

# --- Step 3: Solve in nvim (write + test with Space+cr → :wq when done) ---
echo "[3/4] Opening nvim... (solve → Space+cr to test → :wq when done)"
echo ""
cd "$PROB_DIR"
nvim main.py

# --- Step 4: Test → Submit → Browser → Tag → Insight ---
echo "[4/4] Post-solve flow..."
cp-finish main.py
