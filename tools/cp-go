#!/usr/bin/env bash
# cp-go — continuous practice session. One shortcut, zero friction.
# Loop: select problem → nvim → test → submit → insight → next?
set -euo pipefail

# Ensure tools are in PATH
export PATH="$PATH:$HOME/nixos-cp/tools"

CP_DIR="$HOME/cp"
CACHE_DIR="$HOME/.cache/cp-dashboard"
SESSION_FILE="$CACHE_DIR/session.json"
WATCHLIST="$HOME/nixos-cp/dashboard/watchlist.json"

mkdir -p "$CACHE_DIR"

# Get primary user from watchlist
PRIMARY_USER=$(python3 -c "import json; print(json.load(open('$WATCHLIST'))[0])" 2>/dev/null || echo "")
if [[ -z "$PRIMARY_USER" ]]; then
    echo "Error: Set your username in dashboard/watchlist.json" >&2
    exit 1
fi

STATS_FILE="$CACHE_DIR/stats_${PRIMARY_USER}.json"
if [[ ! -f "$STATS_FILE" ]]; then
    STATS_FILE="$CACHE_DIR/stats.json"
fi

if [[ ! -f "$STATS_FILE" ]]; then
    echo "Error: stats not found. Run fetch_stats.py first." >&2
    exit 1
fi

# --- Session tracking ---
SESSION_COUNT=0
SESSION_START=$(date +%s)
SESSION_LOG=()
SKIP_PIDS=()  # problems already attempted this session

save_session_state() {
    python3 -c "
import json
json.dump({'status': '$1', 'pid': '${CURRENT_PID:-}', 'count': $SESSION_COUNT}, open('$SESSION_FILE', 'w'))
" 2>/dev/null
}

trap 'save_session_state "interrupted"; echo ""; echo "Session interrupted."; show_summary; exit 130' INT

show_summary() {
    if [[ $SESSION_COUNT -eq 0 ]]; then
        return
    fi
    local elapsed=$(( $(date +%s) - SESSION_START ))
    local mins=$(( elapsed / 60 ))
    echo ""
    echo "── Session Complete ──────────────────────"
    echo "  Problems: $SESSION_COUNT"
    echo "  Time:     ${mins} min"
    echo ""
    for entry in "${SESSION_LOG[@]}"; do
        echo "  $entry"
    done
    echo "──────────────────────────────────────────"
}

# --- Check for interrupted session ---
if [[ -f "$SESSION_FILE" ]]; then
    PREV=$(python3 -c "
import json, os
s = json.load(open('$SESSION_FILE'))
if s.get('status') == 'interrupted' and s.get('pid'):
    print(s['pid'])
else:
    print('')
" 2>/dev/null)
    if [[ -n "$PREV" ]]; then
        echo "前回中断: $PREV"
        echo -n "再開する？ (Y/n): "
        read -r RESUME
        if [[ "$RESUME" != "n" && "$RESUME" != "N" ]]; then
            PARTS=(${PREV//_/ })
            CONTEST="${PREV%_*}"
            PROBLEM="${PREV##*_}"
            PROB_DIR="$CP_DIR/contests/$CONTEST/$PROBLEM"
            if [[ -d "$PROB_DIR" ]]; then
                cd "$PROB_DIR"
                nvim main.py
                cp-finish main.py
                SESSION_COUNT=1
                SESSION_LOG+=("$PREV  (resumed)")
            fi
        fi
        rm -f "$SESSION_FILE"
    fi
fi

# --- Main loop ---
while true; do
    # Select problem (pass skip list + SRS data)
    SKIP_LIST=$(IFS=,; echo "${SKIP_PIDS[*]:-}")
    PROBLEM_DATA=$(SKIP="$SKIP_LIST" SRS_FILE="$HOME/cp/srs.json" python3 << 'PYEOF'
import json, random, sys, os, datetime

skip = set(os.environ.get("SKIP", "").split(",")) - {""}
today = datetime.date.today().isoformat()

# Load SRS data
srs = {}
srs_file = os.environ.get("SRS_FILE", "")
if srs_file and os.path.exists(srs_file):
    with open(srs_file) as f:
        srs = json.load(f)

watchlist_path = os.path.expanduser("~/nixos-cp/dashboard/watchlist.json")
try:
    primary = json.load(open(watchlist_path))[0]
except Exception:
    primary = "unknown"
stats_paths = [
    os.path.expanduser(f"~/.cache/cp-dashboard/stats_{primary}.json"),
    os.path.expanduser("~/.cache/cp-dashboard/stats.json"),
]
data = None
for p in stats_paths:
    if os.path.exists(p):
        with open(p) as f:
            data = json.load(f)
        break

if not data:
    print("NONE|||||データなし")
    sys.exit(0)

# Priority 0: SRS review due
for pid, entry in srs.items():
    if entry.get("graduated") or pid in skip:
        continue
    nr = entry.get("next_review")
    if nr and nr <= today:
        parts = pid.rsplit("_", 1)
        contest = parts[0] if len(parts) == 2 else pid
        problem = parts[1] if len(parts) == 2 else "a"
        streak = entry.get("consecutive_ac", 0)
        skips = entry.get("skip_count", 0)
        hint = f" (📖解説読んでから)" if skips >= 2 else ""
        print(f"SRS|{contest}|{problem}|{pid}|復習(SRS): {streak}/2 AC{hint}")
        sys.exit(0)

# Priority 1: WA Queue
wa = data.get("wa_queue", [])
for pick in wa:
    pid = pick["problem_id"]
    if pid in skip:
        continue
    parts = pid.rsplit("_", 1)
    contest = parts[0] if len(parts) == 2 else pid
    problem = parts[1] if len(parts) == 2 else "a"
    print(f"WA|{contest}|{problem}|{pid}|復習: WA×{pick['wa_count']} {pick.get('tag','')} diff{pick.get('difficulty','?')}")
    sys.exit(0)

# Priority 2: Skill tree benchmarks
sg = data.get("skill_graph", {})
nodes = sg.get("nodes", [])
for node in nodes:
    benchmarks = node.get("benchmarks", [])
    for bm in benchmarks:
        if not bm["ac"]:
            pid = bm["id"]
            if pid in skip:
                continue
            parts = pid.rsplit("_", 1)
            contest = parts[0] if len(parts) == 2 else pid
            problem = parts[1] if len(parts) == 2 else "a"
            skill = node.get("label", "")
            print(f"SKILL|{contest}|{problem}|{pid}|スキル: {skill}")
            sys.exit(0)

rating = data.get("difficulty_log", {}).get("current_rating", 0)
print(f"NONE|||||おすすめ問題なし (rating={rating})")
PYEOF
)

    IFS='|' read -r TYPE CONTEST PROBLEM PID MESSAGE <<< "$PROBLEM_DATA"

    if [[ "$TYPE" == "NONE" ]]; then
        echo "$MESSAGE"
        echo "https://kenkoooo.com/atcoder/#/table/"
        break
    fi

    CURRENT_PID="$PID"
    PROB_DIR="$CP_DIR/contests/$CONTEST/$PROBLEM"
    URL="https://atcoder.jp/contests/$CONTEST/tasks/$PID"

    # Setup
    if [[ ! -d "$PROB_DIR" ]]; then
        mkdir -p "$PROB_DIR"
        echo "$URL" > "$PROB_DIR/.problem_url"
        (cd "$PROB_DIR" && oj download "$URL" 2>/dev/null) || true
        touch "$PROB_DIR/main.py"
    fi

    echo ""
    echo "── Problem $((SESSION_COUNT + 1)) ──────────────────────"
    echo "  $PID"
    echo "  $MESSAGE"
    echo "──────────────────────────────────────────"
    echo ""

    save_session_state "solving"

    # Browser
    if command -v firefox &>/dev/null; then
        firefox --new-tab "$URL" &>/dev/null &
        disown
    fi

    # Solve
    PROB_START=$(date +%s)
    cd "$PROB_DIR"
    nvim main.py

    # Post-solve (don't exit on error)
    cp-finish main.py || echo "  (cp-finish had an error, continuing)"

    PROB_ELAPSED=$(( $(date +%s) - PROB_START ))
    PROB_MINS=$(( PROB_ELAPSED / 60 ))

    SESSION_COUNT=$((SESSION_COUNT + 1))
    SESSION_LOG+=("$PID  ${PROB_MINS}min  [$MESSAGE]")
    SKIP_PIDS+=("$PID")

    # Transition
    echo ""
    echo "  ✓ $PID  ${PROB_MINS}min"
    echo ""
    echo -n "  Next? (Y/n): "
    read -r NEXT
    if [[ "$NEXT" == "n" || "$NEXT" == "N" || "$NEXT" == "q" ]]; then
        break
    fi
done

# Session end
rm -f "$SESSION_FILE"
show_summary
