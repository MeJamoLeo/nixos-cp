#!/usr/bin/env bash
# cp-go — clipboard-aware practice launcher.
#
# With an AtCoder problem URL on the clipboard (or as $1):
#   create ~/cp/contests/<contest>/<problem>, run `oj download`,
#   then open main.py in nvim. The browser is assumed to be open already.
#
# Without a usable URL: open NoviSteps in a new Firefox tab.
set -euo pipefail

CP_DIR="$HOME/cp"
URL_RE='^https://atcoder\.jp/contests/[^/]+/tasks/[^/]+$'

read_clipboard() {
    if command -v wl-paste &>/dev/null; then
        wl-paste 2>/dev/null | tr -d '[:space:]' || true
    elif command -v xclip &>/dev/null; then
        xclip -selection clipboard -o 2>/dev/null | tr -d '[:space:]' || true
    fi
}

URL="${1:-$(read_clipboard)}"

if [[ ! "$URL" =~ $URL_RE ]]; then
    if command -v firefox &>/dev/null; then
        firefox --new-tab "https://novisteps.app/" &>/dev/null &
        disown
    fi
    exit 0
fi

URL_CONTEST="${URL#https://atcoder.jp/contests/}"
URL_CONTEST="${URL_CONTEST%%/*}"
PID="${URL##*/tasks/}"
PROBLEM="${PID##*_}"

# ABC/ARC同時開催回 (e.g. abc072/tasks/arc082_a は ABC072のC問題かつ ARC082のA問題)
# は task_id の prefix を canonical contest とみなし、ホスト側コンテストの
# 実問題とディレクトリ衝突しないようにする。
PID_CONTEST="${PID%_*}"
if [[ "$URL_CONTEST" =~ ^(abc|arc|agc)[0-9]+$ ]] \
    && [[ "$PID_CONTEST" =~ ^(abc|arc|agc)[0-9]+$ ]] \
    && [[ "$PID_CONTEST" != "$URL_CONTEST" ]]; then
    CONTEST="$PID_CONTEST"
    URL="https://atcoder.jp/contests/$CONTEST/tasks/$PID"
else
    CONTEST="$URL_CONTEST"
fi

DIR="$CP_DIR/contests/$CONTEST/$PROBLEM"
mkdir -p "$DIR"
echo "$URL" > "$DIR/.problem_url"

if [[ ! -d "$DIR/test" ]]; then
    (cd "$DIR" && oj download "$URL")
fi

[[ ! -f "$DIR/main.py" ]] && touch "$DIR/main.py"

# 直前に解いた問題のACがkenkoooo / NoviSteps に反映された頃に再取得。
(sleep 120 && systemctl --user start fetch-stats.service) &>/dev/null &
disown
(sleep 120 && python3 "$HOME/nixos-cp/dashboard/fetch_novisteps.py" --task "$PID") &>/dev/null &
disown

cd "$DIR"

# Inside tmux: name the window after the task ID (e.g. abc263_c) so window
# lists show "which problem" instead of "nvim" for every entry.
if [[ -n "${TMUX:-}" ]]; then
    tmux rename-window "$PID"
fi

exec nvim main.py
