#!/usr/bin/env bash
# cp-go — open NoviSteps and a Python scratch file.
# Practice flow: solve in nvim using competitest (Space+cr / Space+cs).
set -euo pipefail

WATCHLIST="$HOME/nixos-cp/dashboard/watchlist.json"
USER=$(python3 -c "import json; print(json.load(open('$WATCHLIST'))[0])" 2>/dev/null || echo "")

URL="https://novisteps.app/users/${USER:-}"

if command -v firefox &>/dev/null; then
    firefox --new-tab "$URL" &>/dev/null &
    disown
fi

mkdir -p "$HOME/cp/scratch"
cd "$HOME/cp/scratch"
exec nvim main.py
