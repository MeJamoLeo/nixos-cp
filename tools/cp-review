#!/usr/bin/env bash
# cp-review — review contest problems after contest ends
# Usage: cp-review abc453
set -euo pipefail

CP_DIR="$HOME/cp"
INSIGHTS_DIR="$CP_DIR/insights"
CONTEST="${1:?Usage: cp-review <contest_id> (e.g., abc453)}"
CONTEST_DIR="$CP_DIR/contests/$CONTEST"

if [[ ! -d "$CONTEST_DIR" ]]; then
    echo "Error: $CONTEST_DIR not found" >&2
    exit 1
fi

echo "=== cp-review $CONTEST ==="
echo ""

# Review each problem
for PROB_DIR in "$CONTEST_DIR"/*/; do
    PROBLEM=$(basename "$PROB_DIR")
    SOLUTION="$PROB_DIR/main.py"
    URL_FILE="$PROB_DIR/.problem_url"

    if [[ ! -f "$URL_FILE" ]]; then
        continue
    fi

    URL=$(cat "$URL_FILE")
    PID=$(echo "$URL" | grep -oP '[^/]+$')

    # Check if solution exists and is non-empty
    if [[ ! -s "$SOLUTION" ]]; then
        echo "[$PROBLEM] skipped (no solution)"
        continue
    fi

    echo "--- $PID ---"
    echo ""

    # Tag selection
    TAGS=(
        "全探索" "ソート" "貪欲法" "文字列" "Map/Set" "GCD/LCM" "実装力"
        "累積和" "二分探索" "基礎DP" "BFS/DFS" "尺取り法" "ビット演算"
        "素数/約数" "計算量" "Union-Find" "優先度Queue" "最短路"
        "セグ木/BIT" "bitDP" "MST" "座標圧縮" "mod逆元" "imos法"
        "桁DP" "木DP" "LCA" "強連結成分" "遅延セグ木" "文字列Hash"
        "わからない"
    )

    echo "Tag for $PID:"
    SELECTED_TAG=$(printf '%s\n' "${TAGS[@]}" | fzf --prompt="$PID tag> " --height=15)

    TIMESTAMP=$(date '+%Y-%m-%d %H:%M')
    INSIGHT_FILE="$INSIGHTS_DIR/${PID}.md"

    if [[ ! -f "$INSIGHT_FILE" ]]; then
        echo "# $PID" > "$INSIGHT_FILE"
        echo "" >> "$INSIGHT_FILE"
    fi

    cat >> "$INSIGHT_FILE" << EOF

## REVIEW $TIMESTAMP
tags: [$SELECTED_TAG]

EOF

    CURSOR_LINE=$(wc -l < "$INSIGHT_FILE")
    nvim "+$CURSOR_LINE" "$INSIGHT_FILE"

    # Record in SRS (assume WA if reviewing — user solved during contest or not)
    echo -n "  Contest result? (AC/WA/SKIP) [WA]: "
    read -r CONTEST_RESULT
    CONTEST_RESULT="${CONTEST_RESULT:-WA}"
    CONTEST_RESULT=$(echo "$CONTEST_RESULT" | tr '[:lower:]' '[:upper:]')
    if command -v cp-srs &>/dev/null; then
        cp-srs record "$PID" "$CONTEST_RESULT" 2>/dev/null || true
    fi

    echo "[$PROBLEM] done"
    echo ""
done

# Remove contest mode flag
rm -f "$CONTEST_DIR/.contest_mode"

echo "=== Review complete: $CONTEST ==="
