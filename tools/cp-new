#!/usr/bin/env bash
# cp-new — create contest directory and download test cases
# Usage: cp-new abc453
set -euo pipefail

CP_DIR="$HOME/cp"
CONTEST="${1:?Usage: cp-new <contest_id> (e.g., abc453)}"
CONTEST_DIR="$CP_DIR/contests/$CONTEST"

if [[ -d "$CONTEST_DIR" ]]; then
    echo "Already exists: $CONTEST_DIR"
    exit 1
fi

BASE_URL="https://atcoder.jp/contests/$CONTEST/tasks"

echo "=== cp-new $CONTEST ==="

# Fetch task_ids from the contest's tasks page. This handles ABC/ARC simultaneous
# contests where C/D problems carry the paired ARC's task_id (e.g. abc072's C is
# arc082_a, not abc072_c).
TASK_IDS=$(curl -s "$BASE_URL" \
    | grep -oP "/contests/$CONTEST/tasks/\K[a-z0-9_]+" \
    | awk '!seen[$0]++')

if [[ -z "$TASK_IDS" ]]; then
    echo "Error: no tasks found at $BASE_URL (contest not started or doesn't exist?)" >&2
    exit 1
fi

LETTERS=(a b c d e f g h)
i=0
while IFS= read -r task_id; do
    p="${LETTERS[$i]:-x$i}"
    PROB_DIR="$CONTEST_DIR/$p"
    mkdir -p "$PROB_DIR"

    URL="$BASE_URL/$task_id"
    echo "Downloading: $p ($URL)"

    echo "$URL" > "$PROB_DIR/.problem_url"

    (cd "$PROB_DIR" && oj download "$URL" 2>/dev/null) || echo "  (download failed, skipping)"

    touch "$PROB_DIR/main.py"
    ((i++))
done <<< "$TASK_IDS"

echo ""
echo "Created: $CONTEST_DIR"
echo ""
echo "cd $CONTEST_DIR/a && nvim main.py"
echo "Solve in nvim (Space+cr to test, Space+cs to submit)."
