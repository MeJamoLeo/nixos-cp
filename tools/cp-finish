#!/usr/bin/env bash
# cp-finish вҖ” post-solve flow: test вҶ’ submit вҶ’ tag + insight (during judge) вҶ’ result
# Reordered: tag+insight happen WHILE the judge is running, result is asked LAST
set -euo pipefail

export PATH="$PATH:$HOME/nixos-cp/tools"

CP_DIR="$HOME/cp"
INSIGHTS_DIR="$CP_DIR/insights"
mkdir -p "$INSIGHTS_DIR"

SOLUTION="${1:-main.py}"
SOLUTION=$(realpath "$SOLUTION" 2>/dev/null || echo "$SOLUTION")
PROB_DIR=$(dirname "$SOLUTION")

SKIP_INSIGHT=""
if [[ -f "$PROB_DIR/../.contest_mode" ]] || [[ -f "$PROB_DIR/../../.contest_mode" ]]; then
    SKIP_INSIGHT="1"
fi

if [[ ! -f "$SOLUTION" ]]; then
    echo "Error: $SOLUTION not found" >&2
    exit 1
fi

if [[ -f "$PROB_DIR/.problem_url" ]]; then
    URL=$(cat "$PROB_DIR/.problem_url")
elif [[ -f ".problem_url" ]]; then
    URL=$(cat .problem_url)
else
    echo -n "Problem URL: "
    read -r URL
fi

cd "$PROB_DIR"
PID=$(echo "$URL" | grep -oP '[^/]+$')
TIMESTAMP=$(date '+%Y-%m-%d %H:%M')

# --- Step 1: Local test ---
echo ""
echo "=== Local test ==="
BASENAME=$(basename "$SOLUTION")
case "$BASENAME" in
    *.py)  CMD="python3 ./$BASENAME" ;;
    *.cpp)
        echo "Compiling..."
        g++ -std=c++20 -O2 -Wall -o /tmp/cp_sol "./$BASENAME"
        CMD="/tmp/cp_sol"
        ;;
    *)     CMD="python3 ./$BASENAME" ;;
esac

SKIPPED=""
if ! oj test -c "$CMD"; then
    echo ""
    echo -n "Test FAILED. Submit anyway? (y/N): "
    read -r CONFIRM
    if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
        SKIPPED="1"
    fi
fi

# --- Step 2: Submit (judge starts running) ---
if [[ -z "$SKIPPED" ]]; then
    echo ""
    cp-submit "$SOLUTION"
fi

# --- Contest mode: skip everything else ---
if [[ -n "$SKIP_INSIGHT" ]]; then
    echo ""
    echo "Contest mode: insight skipped. Run 'cp-review' after contest."
    exit 0
fi

# --- Step 3: Tag + Insight (WHILE judge is running вҖ” no waiting) ---
TAGS=(
    "е…ЁжҺўзҙў" "гӮҪгғјгғҲ" "иІӘж¬Іжі•" "ж–Үеӯ—еҲ—" "Map/Set" "GCD/LCM" "е®ҹиЈ…еҠӣ"
    "зҙҜз©Қе’Ң" "дәҢеҲҶжҺўзҙў" "еҹәзӨҺDP" "BFS/DFS" "е°әеҸ–гӮҠжі•" "гғ“гғғгғҲжј”з®—"
    "зҙ ж•°/зҙ„ж•°" "иЁҲз®—йҮҸ" "Union-Find" "е„Әе…ҲеәҰQueue" "жңҖзҹӯи·Ҝ"
    "гӮ»гӮ°жңЁ/BIT" "bitDP" "MST" "еә§жЁҷең§зё®" "modйҖҶе…ғ" "imosжі•"
    "жЎҒDP" "жңЁDP" "LCA" "еј·йҖЈзөҗжҲҗеҲҶ" "йҒ…е»¶гӮ»гӮ°жңЁ" "ж–Үеӯ—еҲ—Hash"
    "гӮҸгҒӢгӮүгҒӘгҒ„"
)

echo ""
echo "Select tag (judge is running, use this time):"
SELECTED_TAG=$(printf '%s\n' "${TAGS[@]}" | fzf --prompt="tag> " --height=15)

INSIGHT_FILE="$INSIGHTS_DIR/${PID}.md"
if [[ ! -f "$INSIGHT_FILE" ]]; then
    echo "# $PID" > "$INSIGHT_FILE"
    echo "" >> "$INSIGHT_FILE"
fi

# Write header (result filled in after)
RESULT_PLACEHOLDER="PENDING"
cat >> "$INSIGHT_FILE" << EOF

## $RESULT_PLACEHOLDER $TIMESTAMP
tags: [$SELECTED_TAG]

EOF

CURSOR_LINE=$(wc -l < "$INSIGHT_FILE")
echo "Writing insight... (:q! to skip)"
nvim "+$CURSOR_LINE" "$INSIGHT_FILE"

# --- Step 4: Result (LAST вҖ” judge should be done by now) ---
RESULT="SKIP"
if [[ -z "$SKIPPED" ]]; then
    echo ""
    echo -n "Result? (AC/WA/TLE/RE) [AC]: "
    read -r RESULT
    RESULT="${RESULT:-AC}"
    RESULT=$(echo "$RESULT" | tr '[:lower:]' '[:upper:]')
fi

# Update insight file with actual result
if command -v sed &>/dev/null; then
    sed -i "s/## $RESULT_PLACEHOLDER $TIMESTAMP/## $RESULT $TIMESTAMP/" "$INSIGHT_FILE" 2>/dev/null || true
fi

echo "Insight saved: $INSIGHT_FILE"

# Record in SRS
if command -v cp-srs &>/dev/null; then
    cp-srs record "$PID" "$RESULT" 2>/dev/null || true
fi

# Trigger dashboard refresh
FETCH_SCRIPT="$HOME/nixos-cp/dashboard/fetch_all.sh"
if [[ -f "$FETCH_SCRIPT" ]]; then
    bash "$FETCH_SCRIPT" &>/dev/null &
    disown
fi
