#!/usr/bin/env bash
# cp-finish — post-solve flow: test → submit → tag + insight (during judge) → result
# Reordered: tag+insight happen WHILE the judge is running, result is asked LAST
set -euo pipefail

export PATH="$PATH:$HOME/nixos-cp/tools"

CP_DIR="$HOME/cp"
INSIGHTS_DIR="$CP_DIR/insights"
mkdir -p "$INSIGHTS_DIR"

LIGHT_MODE=""
SOLUTION=""
for arg in "$@"; do
    case "$arg" in
        --light) LIGHT_MODE="1" ;;
        *) SOLUTION="$arg" ;;
    esac
done
SOLUTION="${SOLUTION:-main.py}"
SOLUTION=$(realpath "$SOLUTION" 2>/dev/null || echo "$SOLUTION")
PROB_DIR=$(dirname "$SOLUTION")

SKIP_INSIGHT=""
if [[ -f "$PROB_DIR/../.contest_mode" ]] || [[ -f "$PROB_DIR/../../.contest_mode" ]]; then
    SKIP_INSIGHT="1"
fi

if [[ ! -f "$SOLUTION" ]]; then
    echo "Error: $SOLUTION not found" >&2
    exit 1
fi

if [[ -f "$PROB_DIR/.problem_url" ]]; then
    URL=$(cat "$PROB_DIR/.problem_url")
elif [[ -f ".problem_url" ]]; then
    URL=$(cat .problem_url)
else
    echo -n "Problem URL: "
    read -r URL
fi

cd "$PROB_DIR"
PID=$(echo "$URL" | grep -oP '[^/]+$')
TIMESTAMP=$(date '+%Y-%m-%d %H:%M')

# --- Step 1: Local test ---
echo ""
echo "=== Local test ==="
BASENAME=$(basename "$SOLUTION")
case "$BASENAME" in
    *.py)  CMD="python3 ./$BASENAME" ;;
    *.cpp)
        echo "Compiling..."
        g++ -std=c++20 -O2 -Wall -o /tmp/cp_sol "./$BASENAME"
        CMD="/tmp/cp_sol"
        ;;
    *)     CMD="python3 ./$BASENAME" ;;
esac

SKIPPED=""
if ! oj test -c "$CMD"; then
    echo ""
    echo -n "Test FAILED. Submit anyway? (y/N): "
    read -r CONFIRM
    if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
        SKIPPED="1"
    fi
fi

# --- Step 2: Submit (judge starts running) ---
if [[ -z "$SKIPPED" ]]; then
    echo ""
    cp-submit "$SOLUTION"
fi

# --- Contest mode: skip everything else ---
if [[ -n "$SKIP_INSIGHT" ]]; then
    echo ""
    echo "Contest mode: insight skipped. Run 'cp-review' after contest."
    exit 0
fi

# --- Light mode: skip tag + insight (warmup problems) ---
if [[ -n "$LIGHT_MODE" ]]; then
    echo "  (warmup: tag+insight skipped)"
    if command -v cp-srs &>/dev/null; then
        cp-srs record "$PID" "${RESULT:-AC}" 2>/dev/null || true
    fi
    FETCH_SCRIPT="$HOME/nixos-cp/dashboard/fetch_all.sh"
    if [[ -f "$FETCH_SCRIPT" ]]; then
        bash "$FETCH_SCRIPT" &>/dev/null &
        disown
    fi
    exit 0
fi

# --- Step 3: Result ---
RESULT="SKIP"
if [[ -z "$SKIPPED" ]]; then
    echo ""
    echo -n "Result? (AC/EAC/WA/TLE/RE) [AC]: "
    read -r RESULT
    RESULT="${RESULT:-AC}"
    RESULT=$(echo "$RESULT" | tr '[:lower:]' '[:upper:]')
fi

# --- Step 4: Tag + Insight (user decides) ---
echo ""
echo -n "Insight書く？ (Y/n): "
read -r WRITE_INSIGHT

if [[ "$WRITE_INSIGHT" != "n" && "$WRITE_INSIGHT" != "N" ]]; then
    TAGS=(
        "全探索 brute-force"
        "ソート sort"
        "貪欲法 greedy"
        "文字列 string"
        "Map/Set map-set"
        "GCD/LCM gcd-lcm"
        "実装力 implementation"
        "累積和 prefix-sum"
        "二分探索 binary-search"
        "基礎DP basic-dp"
        "BFS/DFS bfs-dfs graph"
        "尺取り法 two-pointers"
        "ビット演算 bit"
        "素数/約数 prime divisor"
        "計算量 complexity"
        "Union-Find union-find dsu"
        "優先度Queue priority-queue heap"
        "最短路 shortest-path dijkstra"
        "セグ木/BIT segment-tree bit-indexed"
        "bitDP bitmask-dp"
        "MST minimum-spanning-tree"
        "座標圧縮 coordinate-compression"
        "mod逆元 mod-inverse"
        "imos法 imos"
        "桁DP digit-dp"
        "木DP tree-dp"
        "LCA lowest-common-ancestor"
        "強連結成分 scc strongly-connected"
        "遅延セグ木 lazy-segment-tree"
        "文字列Hash string-hash rolling-hash"
        "解説AC editorial"
        "わからない unknown"
    )

    # Auto-suggest tag from problem source
    FZF_QUERY=""
    if [[ -f "$PROB_DIR/.suggested_tag" ]]; then
        SUGGESTED=$(cat "$PROB_DIR/.suggested_tag")
        FZF_QUERY=$(echo "$SUGGESTED" | grep -oP 'スキル: \K.*|ウォームアップ: \K(?!diff)\S+' | head -1 || true)
    fi

    echo "Select tag:"
    SELECTED_RAW=$(printf '%s\n' "${TAGS[@]}" | fzf --prompt="tag> " --height=15 --query="$FZF_QUERY")
    SELECTED_TAG=$(echo "$SELECTED_RAW" | awk '{print $1}')

    INSIGHT_FILE="$INSIGHTS_DIR/${PID}.md"
    if [[ ! -f "$INSIGHT_FILE" ]]; then
        echo "# $PID" > "$INSIGHT_FILE"
        echo "" >> "$INSIGHT_FILE"
    fi

    cat >> "$INSIGHT_FILE" << EOF

## $RESULT $TIMESTAMP
tags: [$SELECTED_TAG]

EOF

    CURSOR_LINE=$(wc -l < "$INSIGHT_FILE")
    nvim "+$CURSOR_LINE" "$INSIGHT_FILE"
    echo "Insight saved: $INSIGHT_FILE"
fi

# Record in SRS
if command -v cp-srs &>/dev/null; then
    cp-srs record "$PID" "$RESULT" 2>/dev/null || true
fi

# Trigger dashboard refresh
FETCH_SCRIPT="$HOME/nixos-cp/dashboard/fetch_all.sh"
if [[ -f "$FETCH_SCRIPT" ]]; then
    bash "$FETCH_SCRIPT" &>/dev/null &
    disown
fi
